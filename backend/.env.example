# PhishGuard Backend — Environment Variables
# Copy this file to .env and fill in your values

# ── Google Safe Browsing API ─────────────────────────────────
# Free key: https://console.cloud.google.com/
# Enable "Safe Browsing API" → Credentials → Create API Key
# Free quota: 10 000 requests/day
GOOGLE_SAFE_BROWSING_KEY=your_key_here

# ── Risk thresholds (optional, defaults shown) ───────────────
# PHISHING_THRESHOLD=60
# SUSPICIOUS_MIN=30
